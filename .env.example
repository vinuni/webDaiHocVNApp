# Copy to .env and set your Laravel API base URL (no trailing slash).
# Web / iOS Simulator: http://localhost:8000
# Android Emulator: http://10.0.2.2:8000
# Physical device (Expo Go): http://YOUR_PC_IP:8000 (e.g. http://192.168.1.100:8000)
# See docs/LOGIN_EXPO_GO.md for how to log in on Expo Go.
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.203:8000

# Error reporting (send app errors to backend)
# Set to "false" to disable; omit or "true" to enable.
EXPO_PUBLIC_ERROR_REPORTING_ENABLED=true
# Sample rate: 1.0 = 100%, 0.1 = 10% of errors reported (for production throttling).
EXPO_PUBLIC_ERROR_SAMPLE_RATE=1.0

# Google Sign-In (Login / Register with Google). See APP.md "Google Sign-In (OAuth)" for setup.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=     # Web client ID from Google Cloud Console
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=     # iOS client ID (optional for iOS / Expo Go)
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID= # Android client ID (optional for Android)
