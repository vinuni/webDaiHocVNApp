# Copy to .env and set your Laravel API base URL (no trailing slash).
# Web / iOS Simulator: http://localhost:8000
# Android Emulator: http://10.0.2.2:8000
# Physical device (Expo Go): http://YOUR_PC_IP:8000 (e.g. http://192.168.1.100:8000)
# See docs/LOGIN_EXPO_GO.md for how to log in on Expo Go.
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.203:8000
